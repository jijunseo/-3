# ─────────────────────────────────────────────────────
#  RecoveryBot 환경변수 설정 파일
#  이 파일을 복사해서 .env 로 저장한 뒤 값을 채워주세요
#  cp .env.example .env
# ─────────────────────────────────────────────────────

# [필수] 디스코드 봇 토큰
# https://discord.com/developers/applications 에서 발급
BOT_TOKEN=여기에_봇_토큰_입력

# [선택] 봇 접두사 (기본값: !)
PREFIX=!

# [선택] 로그를 전송할 채널 ID (0이면 비활성화)
# 채널 ID는 디스코드에서 개발자 모드 켜고 채널 우클릭 → "ID 복사"
LOG_CHANNEL_ID=0

# [선택] 자동 백업 주기 (초 단위, 기본값: 21600 = 6시간)
AUTO_BACKUP_INTERVAL=21600

# [선택] 복구/백업 명령어 사용 가능한 역할 이름
# 비워두면 서버 "관리자(Administrator)" 권한만 체크
ADMIN_ROLE_NAME=
